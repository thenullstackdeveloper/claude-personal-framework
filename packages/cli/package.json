{
  "name": "@claude-fw/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "claude-fw": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reports": {
      "types": "./dist/reports.d.ts",
      "default": "./dist/reports.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@claude-fw/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
